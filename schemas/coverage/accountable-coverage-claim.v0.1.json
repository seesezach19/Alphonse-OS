{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.alphonse.local/coverage/accountable-coverage-claim.v0.1.json",
  "title": "Accountable Coverage Claim v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "onboarding_id", "workflow_reference", "capability_vector_digest", "policy", "assessment_interval", "evidence_cutoff", "required_capability_states", "coverage_status", "meets_policy", "gap_ids", "limitation_ids", "claims_destination_commitment", "authority"],
  "properties": {
    "schema_version": { "const": "alphonse.accountable-coverage-claim.v0.1" },
    "onboarding_id": { "type": "string", "format": "uuid" },
    "workflow_reference": { "$ref": "#/$defs/workflow_reference" },
    "capability_vector_digest": { "$ref": "#/$defs/digest" },
    "policy": { "oneOf": [{ "$ref": "#/$defs/policy" }, { "type": "null" }] },
    "assessment_interval": { "$ref": "#/$defs/assessment_interval" },
    "evidence_cutoff": { "$ref": "#/$defs/evidence_cutoff" },
    "required_capability_states": {
      "type": "object", "additionalProperties": false, "maxProperties": 9,
      "properties": {
        "discovered": { "$ref": "#/$defs/state" },
        "connected": { "$ref": "#/$defs/state" },
        "revision_bound": { "$ref": "#/$defs/state" },
        "execution_observed": { "$ref": "#/$defs/state" },
        "diagnosable": { "$ref": "#/$defs/state" },
        "behavior_monitored": { "$ref": "#/$defs/state" },
        "repair_bound": { "$ref": "#/$defs/state" },
        "verification_ready": { "$ref": "#/$defs/state" },
        "promotion_ready": { "$ref": "#/$defs/state" }
      }
    },
    "coverage_status": { "enum": ["covered", "partial", "indeterminate", "not_covered", "unavailable"] },
    "meets_policy": { "type": ["boolean", "null"] },
    "gap_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/digest" } },
    "limitation_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/digest" } },
    "claims_destination_commitment": { "const": false },
    "authority": { "const": "none" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "state": { "enum": ["established", "not_established", "indeterminate", "unavailable"] },
    "capability": { "enum": ["discovered", "connected", "revision_bound", "execution_observed", "diagnosable", "behavior_monitored", "repair_bound", "verification_ready", "promotion_ready"] },
    "workflow_reference": {
      "type": "object", "additionalProperties": false,
      "required": ["system", "environment", "provider_workflow_id"],
      "properties": {
        "system": { "type": "string", "minLength": 1, "maxLength": 200 },
        "environment": { "type": "string", "minLength": 1, "maxLength": 200 },
        "provider_workflow_id": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    },
    "evidence_cutoff": {
      "type": "object", "additionalProperties": false,
      "required": ["cutoff_type", "cutoff_id", "cutoff_digest", "occurred_at"],
      "properties": {
        "cutoff_type": { "type": "string", "minLength": 1, "maxLength": 100 },
        "cutoff_id": { "type": "string", "minLength": 1, "maxLength": 200 },
        "cutoff_digest": { "$ref": "#/$defs/digest" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "policy": {
      "type": "object", "additionalProperties": false,
      "required": ["profile_id", "version", "profile_digest", "consequence_class", "required_capabilities", "maximum_evidence_age_seconds"],
      "properties": {
        "profile_id": { "type": "string", "minLength": 3, "maxLength": 160 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "profile_digest": { "$ref": "#/$defs/digest" },
        "consequence_class": { "enum": ["low", "moderate", "high", "critical"] },
        "required_capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/capability" } },
        "maximum_evidence_age_seconds": { "type": "integer", "minimum": 60, "maximum": 31536000 }
      }
    },
    "assessment_interval": {
      "type": "object", "additionalProperties": false,
      "required": ["starts_at", "ends_at", "end_exclusive"],
      "properties": {
        "starts_at": { "type": "string", "format": "date-time" },
        "ends_at": { "type": "string", "format": "date-time" },
        "end_exclusive": { "const": false }
      }
    }
  }
}
