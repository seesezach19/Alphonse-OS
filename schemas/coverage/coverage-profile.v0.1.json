{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.alphonse.local/coverage/coverage-profile.v0.1.json",
  "title": "Coverage Profile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "version", "consequence_class", "required_capabilities", "maximum_evidence_age_seconds", "assessment_policy", "authority"],
  "properties": {
    "schema_version": { "const": "alphonse.coverage-profile.v0.1" },
    "profile_id": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{2,159}$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "consequence_class": { "enum": ["low", "moderate", "high", "critical"] },
    "required_capabilities": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/capability" } },
    "maximum_evidence_age_seconds": { "type": "integer", "minimum": 60, "maximum": 31536000 },
    "assessment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_required_established", "partial", "indeterminate", "unavailable", "not_established"],
      "properties": {
        "all_required_established": { "const": "covered" },
        "partial": { "const": "partial" },
        "indeterminate": { "const": "indeterminate" },
        "unavailable": { "const": "not_covered" },
        "not_established": { "const": "not_covered" }
      }
    },
    "authority": { "const": "none" }
  },
  "$defs": {
    "capability": { "enum": ["discovered", "connected", "revision_bound", "execution_observed", "diagnosable", "behavior_monitored", "repair_bound", "verification_ready", "promotion_ready"] }
  }
}
