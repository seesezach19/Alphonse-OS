{
  "package_id": "alphonse.runtime.n8n",
  "package_version": "0.3.0",
  "compatibility": {
    "n8n": ">=2.25.0 <3.0.0",
    "reference_version": "2.25.7",
    "reference_image": "n8nio/n8n@sha256:761374d4eb841b0a22771d6bd68f0e8d827b4979ae4e490045517b13fc1259dd"
  },
  "exports": {
    "workflow_runtime_adapter": "runtime-adapter-manifest.json",
    "repair_delivery_adapter": "repair-delivery-adapter-manifest.json",
    "verification_adapter": "verification-adapter-manifest.json",
    "event_reporter_workflow": "workflows/alphonse-event-reporter.json",
    "reference_workflow": "workflows/inventory-follow-up-defective.json"
  },
  "mappings": {
    "workflow_inventory": "credential-scoped n8n public API workflow pages to typed untrusted metadata with signed scope-bound cursors",
    "workflow_identity": "n8n workflow id to Alphonse workflow_id",
    "revision_identity": "exported workflow JSON, runtime image, node versions, model declaration, and configuration",
    "event_receipt": "successful n8n execution to signed minimal Runtime Event Envelope",
    "health": "runtime and reporting reachability evaluated separately from workflow activity",
    "repair_delivery": "provider-neutral repair patch to inactive n8n workflow and Owner-authorized target promotion through the public API",
    "verification": "exact n8n Code-node revisions to deterministic provider-neutral outcomes"
  },
  "fingerprint_rules": {
    "canonicalization": "alphonse-canonical-json-v1",
    "included_fields": [
      "workflow.nodes", "workflow.connections", "workflow.settings", "dependency.nodes",
      "dependency.connections", "runtime.version", "runtime.image_digest", "node.typeVersion",
      "model", "configuration", "adapter.version"
    ],
    "excluded_fields": ["credentials", "createdAt", "updatedAt", "execution_payload"],
    "provider_parameter_defaults": {
      "n8n-nodes-base.manualTrigger": { "notice": "" },
      "n8n-nodes-base.code": {
        "language": "javaScript", "mode": "runOnceForAllItems", "notice": ""
      },
      "n8n-nodes-base.executeWorkflow": {
        "mode": "once", "operation": "call_workflow", "source": "database"
      }
    }
  },
  "health_checks": {
    "runtime_reachability": "GET /healthz",
    "reporting_reachability": "signed probe is accepted by Alphonse",
    "workflow_activity": "last accepted event, reported separately and allowed to be none_observed"
  },
  "detail_policy": {
    "policy_id": "alphonse.runtime.n8n.detail.v1",
    "extract_paths": ["input.order", "input.customer_email", "fixtures", "output"],
    "redact_paths": ["input.customer_email"],
    "omit_paths": ["credentials", "runtime.logs", "input.internal_notes"],
    "replacement": "[REDACTED]",
    "adapter_omitted_fields": ["credentials", "runtime.logs", "input.internal_notes"]
  },
  "custody": {
    "n8n_credentials": "customer-owned n8n only",
    "alphonse_adapter_secret": "runtime environment only",
    "repair_delivery_authentication": "customer-local environment only; binding reference persisted",
    "routine_business_payloads": "digest only",
    "direct_n8n_database_access": "prohibited"
  },
  "tests": [
    "manifest_conformance", "workflow_import", "event_reporter_primitives",
    "real_n8n_successful_but_wrong_execution", "exact_revision_resolution", "no_external_effects",
    "inactive_candidate_materialization", "active_workflow_preservation", "repair_delivery_drift_fencing",
    "independent_deterministic_verification", "negative_candidate_rejection",
    "owner_authorized_promotion", "exact_target_confirmation", "rollback_snapshot_preservation"
  ]
}
